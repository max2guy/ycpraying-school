{
  "rules": {
    "members": {
      ".read": true,
      ".write": true
    },
    "presence": {
      ".read": true,
      ".write": true
    },
    "messages": {
      ".read": true,
      ".write": true
    },
    "centerNode": {
      ".read": true,
      ".write": true
    },
    "fcmTokens": {
      ".read": false,
      ".write": true
    },
    "prayerEvents": {
      ".read": false,
      ".write": true
    },
    "missions": {
      ".read": true,
      "$date": {
        "$sessionId": {
          ".write": true
        }
      }
    },
    "missionAliases": {
      ".read": true,
      ".write": true
    },
    "guessWhoParticipants": {
      ".read": false,
      "$sessionId": {
        ".write": true
      }
    },
    "guessWhoCandidates": {
      ".read": "now >= 1785078000000",
      ".write": true
    },
    "guessWhoAnswers": {
      ".read": false,
      "$sessionId": {
        ".write": "!data.exists()"
      }
    },
    "guessWhoResults": {
      ".read": true,
      ".write": false
    },
    "guessWhoGame": {
      ".read": true,
      ".write": false
    },
    "appConfig": {
      "requiredVersion": {
        ".read": true,
        ".write": "auth != null"
      },
      "broadcastPush": {
        ".read": false,
        ".write": "auth != null"
      }
    },
  }
}
