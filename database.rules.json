{
  "rules": {
    "members": {
      ".read": true,
      "$memberId": {
        ".write": "auth != null && (auth.token.email === 'admin@church.com' || (!data.exists() && newData.child('ownerUid').val() === auth.uid) || (data.child('ownerUid').val() === auth.uid && newData.child('ownerUid').val() === auth.uid))",
        "prayers": {
          "$prayerIndex": {
            "amens": {
              "$amenUid": {
                ".write": "auth != null && auth.uid === $amenUid && (newData.val() === true || !newData.exists())"
              }
            }
          }
        }
      }
    },
    "presence": {
      ".read": true,
      "$uid": { ".write": "auth != null && $uid === auth.uid" }
    },
    "messages": {
      ".read": true,
      ".write": "auth != null"
    },
    "centerNode": {
      ".read": true,
      ".write": true
    },
    "fcmTokens": {
      ".read": false,
      "$uid": { ".write": "auth != null && $uid === auth.uid" }
    },
    "notificationDiagnostics": {
      ".read": false,
      "$sessionId": {
        ".write": "auth != null && $sessionId === auth.uid"
      }
    },
    "prayerEvents": {
      ".read": false,
      ".write": true
    },
    "missions": {
      ".read": true,
      "$date": {
        "$sessionId": {
          ".write": "auth != null && auth.token.email === 'admin@church.com'"
        }
      }
    },
    "missionAliases": {
      ".read": true,
      "$alias": { ".write": "auth != null && (!data.exists() ? newData.val() === auth.uid : data.val() === auth.uid && newData.val() === auth.uid)" }
    },
    "guessWhoParticipants": {
      ".read": false,
      "$sessionId": {
        ".read": "auth != null && $sessionId === auth.uid",
        ".write": "auth != null && $sessionId === auth.uid"
      }
    },
    "guessWhoCandidates": {
      ".read": "now >= 1785013200000",
      ".write": "auth != null"
    },
    "guessWhoAnswers": {
      ".read": false,
      "$sessionId": {
        ".write": "auth != null && $sessionId === auth.uid && !data.exists()"
      }
    },
    "guessWhoResults": {
      ".read": true,
      ".write": false
    },
    "guessWhoGame": {
      ".read": true,
      ".write": false
    },
    "appConfig": {
      "requiredVersion": {
        ".read": true,
        ".write": "auth != null"
      },
      "broadcastPush": {
        ".read": false,
        ".write": "auth != null"
      }
    }
  }
}
